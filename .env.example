# =============================================================================
# REQUIRED — App will crash on startup without these
# =============================================================================

# Spotify Integration
# How to get these: https://developer.spotify.com/documentation/web-api
# 1. Go to https://developer.spotify.com/dashboard → Create app
# 2. Set redirect URI to http://localhost:3000
# 3. Get CLIENT_ID and CLIENT_SECRET from app settings
# 4. Use the auth flow to get REFRESH_TOKEN:
#    → https://github.com/tobika/spotify-auth-refresh-token-example
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# =============================================================================
# OPTIONAL — Contact form will log to console if not set
# =============================================================================

# SMTP Email (for contact form)
# Recommended providers: Resend, Mailgun, Gmail, Brevo
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your@gmail.com
#   SMTP_PASS=your-app-password  ← NOT your Gmail password, use App Password
#   Guide: https://support.google.com/accounts/answer/185833
#
# Resend example (recommended — easier than Gmail):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx  ← API key from resend.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where contact form submissions get sent
CONTACT_EMAIL=your@email.com

# =============================================================================
# OPTIONAL — Monitoring & Analytics
# =============================================================================

# Sentry error tracking
# Get DSN from: https://sentry.io → Create project → Next.js
NEXT_PUBLIC_SENTRY_DSN=

# Cloudflare Web Analytics
# Get token from: Cloudflare Dashboard → Web Analytics → Add site
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Cloudflare Turnstile (contact form bot protection)
# Get keys from: Cloudflare Dashboard → Turnstile → Add site
# Site key goes to NEXT_PUBLIC_ (used in browser)
# Secret key stays server-side only
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
