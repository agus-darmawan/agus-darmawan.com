# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Spotify — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Contact Form
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# SMTP (if not set, form submissions log to console)
# Gmail: use App Password, not your actual password
# Resend: SMTP_USER=resend, SMTP_PASS=re_xxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
CONTACT_EMAIL=your@email.com

# Cloudflare Turnstile — https://dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Monitoring & Analytics
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Sentry — https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Cloudflare Web Analytics beacon token
NEXT_PUBLIC_CF_BEACON_TOKEN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL — Infrastructure
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Cloudflare R2 content CDN
NEXT_PUBLIC_CONTENT_URL=https://content.your-domain.com

# Cloudflare Worker for Spotify (optional, falls back to /api/spotify)
NEXT_PUBLIC_SPOTIFY_WORKER_URL=

# App base URL — used for OG image and social meta
# Dev: http://localhost:3000 | Prod: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare Analytics API (for visitor counter in terminal)
CF_ACCOUNT_ID=
CF_SITE_TAG=
CF_API_TOKEN=

# GitHub token (optional — increases API rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=
