# Spotify API credentials
# GET these from https://developer.spotify.com/dashboard/applications
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REFRESH_TOKEN=your_refresh_token

# Contact form — SMTP (works with Gmail, Zoho, any SMTP provider)
# Gmail: enable "App Passwords" at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
CONTACT_EMAIL=your@gmail.com   # where messages are delivered (defaults to SMTP_USER)
